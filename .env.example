# AlphaVision environment configuration template.
# Copy to `.env` and fill in real values; `.env` is git-ignored.

# Finnhub free-tier API key (https://finnhub.io). Used by the analyst
# provider for upgrade/downgrade history, recommendation snapshots,
# and consensus price targets. Free tier: 60 calls/min.
FINNHUB_API_KEY=

# SEC EDGAR identity string (Fair-Access policy requires a contact).
# Format: "Organisation Name contact@example.com". Used by edgartools
# when pulling 10-Q / 10-K XBRL facts.
EDGAR_IDENTITY=AlphaVision Research research@alphavision.local

# Azure Blob Storage connection string (Phase 6: weekly DB backup).
AZURE_BLOB_CONNECTION_STRING=
